# Capa de IA (Claude) — la IA ya está prendida en config.yaml (ai.enabled: true).
# Pegá tu key acá (o exportala en el entorno) y la IA se activa sola.
# Sin esta key el bot corre igual: la IA cae a "solo-reglas".
ANTHROPIC_API_KEY=

# Solo para fases de ejecución en OKX (broker.kind: okx_demo). En paper no hacen falta.
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_API_PASSWORD=

# ── Deploy con Docker / Coolify ─────────────────────────────────────────
# Símbolo que opera el worker `bot` (un solo símbolo por contenedor).
BOT_SYMBOL=BTC/USDT

# Puerto público del panel en el host (solo para `docker compose` local;
# en Coolify se asigna un dominio al servicio `web` y esto se ignora).
WEB_PORT=8080

# Orígenes permitidos por CORS en la API. Con el proxy de nginx el panel
# es same-origin, así que "*" alcanza. Acotalo a tu dominio si exponés la API directo.
AMERICO_CORS_ORIGINS=*
