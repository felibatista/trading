# Variables de entorno de AMÉRICO. Copiá este archivo a .env (gitignored) y
# completá lo que necesites.
#
# ⚡ PARA ARRANCAR EN PAPER NO HACE FALTA NINGUNA: corre con SQLite, las 5
#    cuentas en paper sobre precios reales de OKX, y la IA cae a solo-reglas.
#    `docker compose up` y listo.

# ── IA (Claude / OpenAI) ─────────────────────────────────────────────────
# Filtro de IA que VETA entradas dudosas, por cuenta. config.docker.yaml ya
# tiene ai.enabled: true, así que con SOLO pegar la key del proveedor se activa.
# Cada cuenta elige su proveedor (anthropic/openai) y modelo desde el panel.
# Pegá la key del/los proveedor(es) que vayas a usar. Sin la key correspondiente,
# esa cuenta cae a solo-reglas (sin romper nada).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Base de datos ────────────────────────────────────────────────────────
# Opcional. Sin esto usa SQLite en el volumen /data (un contenedor, self-contained).
# En Coolify: creá un Postgres gestionado y pegá su URL acá (corre en Postgres
# sin cambiar código). Formato: postgresql://usuario:pass@host:5432/basededatos
DATABASE_URL=

# ── Panel / red ──────────────────────────────────────────────────────────
# Puerto del panel en tu máquina (solo `docker compose` local; en Coolify
# asignás un dominio al servicio y esto se ignora).
WEB_PORT=8080
# Orígenes CORS de la API. El panel es same-origin (FastAPI lo sirve), así que "*" alcanza.
AMERICO_CORS_ORIGINS=*

# ── OKX (solo si pasás a ejecución real-demo) ────────────────────────────
# En PAPER no hacen falta. Solo si cambiás broker.kind a okx_demo en config.docker.yaml
# (ejecuta contra el order book demo de OKX con balance virtual).
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_API_PASSWORD=
